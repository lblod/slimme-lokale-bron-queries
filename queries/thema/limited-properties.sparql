PREFIX ext: <http://mu.semte.ch/vocabularies/ext/>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX ex: <http://www.example.org#>
PREFIX eli: <http://data.europa.eu/eli/ontology#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
select DISTINCT
?decision ?thema  ?themaLabel

WHERE {

  {
    SELECT  ?decision  ?thema ?themaLabel
    WHERE {
      ?s a <http://data.vlaanderen.be/ns/besluit#Zitting>;
         <http://data.vlaanderen.be/ns/besluit#behandelt>/^<http://purl.org/dc/terms/subject> ?subject.
      ?subject prov:generated ?decision.
     ?thema skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/BesluitThema>; skos:prefLabel ?themaLabel.
     ?decision dct:subject ?thema .
      
    }
    ORDER BY ?datePublication
    LIMIT 50      
    OFFSET 0      
  }
}
